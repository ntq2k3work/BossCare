DATABASE_URL="postgresql://pet_healthy:pet_healthy@localhost:5432/pet_healthy?schema=public"
AUTH_STORE="prisma"
# Optional production email delivery for registration OTP.
# Without RESEND_API_KEY, local dev logs OTP and returns devOtp for testing.
RESEND_API_KEY=""
AUTH_EMAIL_FROM="BossCare <onboarding@resend.dev>"
# Optional Gemini access for AI Care Guide.
# When unset, the app falls back to grounded local answers.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"
